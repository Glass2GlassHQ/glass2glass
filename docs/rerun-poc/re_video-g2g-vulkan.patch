@@ -0,0 +1,107 @@
+//! A decoded video frame kept GPU-resident: the zero-copy ("Tier B") output shape.
+//!
+//! A hardware decode backend that produces frames directly on the GPU (already
+//! colour-converted to RGBA) puts a [`GpuVideoFrame`] on
+//! [`super::FrameContent::gpu_texture`] and leaves `data` empty, so the frame is
+//! never read back to the CPU. A consumer (e.g. `re_renderer`) renders the texture
+//! directly, skipping both the readback and its own upload + YUV->RGB.
+//!
+//! This type is backend-agnostic: it is a plain `wgpu::Texture` plus the wgpu
+//! device/queue/adapter it is bound to. It is gated behind the `gpu-textures`
+//! feature so `re_video`'s default build takes no `wgpu` dependency.
+
+/// A decoded frame that lives in GPU memory as a `wgpu::Texture`.
+///
+/// The texture is bound to the enclosed `device`, so a consumer MUST render it on
+/// that device. A hardware decoder commonly creates its own device with
+/// capabilities a render-only device omits (e.g. Vulkan video-decode queue
+/// families), so the correct direction is for the renderer to run on the decode
+/// device; on a host whose display GPU differs from the decode GPU a cross-device
+/// copy is unavoidable (fall back to the CPU-readback path there).
+#[derive(Clone)]
+pub struct GpuVideoFrame {
+    /// The decoded frame, colour-converted and ready to sample (typically
+    /// `Rgba8Unorm`). Reference counted; cloning is cheap.
+    pub texture: wgpu::Texture,
+
+    /// The device the `texture` is bound to. Render it on this device.
+    pub device: wgpu::Device,
+
+    /// The queue paired with `device` (for readback / further GPU work).
+    pub queue: wgpu::Queue,
+
+    /// The adapter `device` was opened on (a consumer building a renderer on this
+    /// device needs it, e.g. `re_renderer::RenderContext::new`).
+    pub adapter: wgpu::Adapter,
+}
+
+impl std::fmt::Debug for GpuVideoFrame {
+    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
+        f.debug_struct("GpuVideoFrame")
+            .field("width", &self.texture.width())
+            .field("height", &self.texture.height())
+            .field("format", &self.texture.format())
+            .finish_non_exhaustive()
+    }
+}
+
+impl GpuVideoFrame {
+    /// Read the texture back to packed RGBA8 (`width * height * 4`) on the CPU.
+    ///
+    /// A verification / debug / cross-device-fallback helper, NOT the zero-copy
+    /// path: a real consumer renders `texture` on `device` directly. The texture
+    /// must be `Rgba8Unorm`-shaped (4 bytes/texel) and have `COPY_SRC` usage.
+    pub fn read_rgba(&self) -> Vec<u8> {
+        let w = self.texture.width();
+        let h = self.texture.height();
+        let tight = (w * 4) as usize;
+        // wgpu requires bytes_per_row be a multiple of 256 for texture->buffer copies.
+        let padded = tight.div_ceil(256) * 256;
+        let buffer = self.device.create_buffer(&wgpu::BufferDescriptor {
+            label: Some("GpuVideoFrame::read_rgba"),
+            size: (padded * h as usize) as u64,
+            usage: wgpu::BufferUsages::MAP_READ | wgpu::BufferUsages::COPY_DST,
+            mapped_at_creation: false,
+        });
+        let mut enc = self
+            .device
+            .create_command_encoder(&wgpu::CommandEncoderDescriptor { label: None });
+        enc.copy_texture_to_buffer(
+            wgpu::TexelCopyTextureInfo {
+                texture: &self.texture,
+                mip_level: 0,
+                origin: wgpu::Origin3d::ZERO,
+                aspect: wgpu::TextureAspect::All,
+            },
+            wgpu::TexelCopyBufferInfo {
+                buffer: &buffer,
+                layout: wgpu::TexelCopyBufferLayout {
+                    offset: 0,
+                    bytes_per_row: Some(padded as u32),
+                    rows_per_image: Some(h),
+                },
+            },
+            wgpu::Extent3d { width: w, height: h, depth_or_array_layers: 1 },
+        );
+        self.queue.submit([enc.finish()]);
+        let slice = buffer.slice(..);
+        let (tx, rx) = std::sync::mpsc::channel();
+        slice.map_async(wgpu::MapMode::Read, move |r| {
+            let _ = tx.send(r);
+        });
+        self.device
+            .poll(wgpu::PollType::Wait { submission_index: None, timeout: None })
+            .expect("poll for readback");
+        rx.recv().expect("readback channel").expect("map readback buffer");
+        let mapped = slice.get_mapped_range();
+        // Drop the per-row padding back to a tight w*4 stride.
+        let mut out = Vec::with_capacity(tight * h as usize);
+        for row in 0..h as usize {
+            let start = row * padded;
+            out.extend_from_slice(&mapped[start..start + tight]);
+        }
+        drop(mapped);
+        buffer.unmap();
+        out
+    }
+}

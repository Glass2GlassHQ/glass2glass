+/// A registered hardware-decode backend's outcome for one video.
+#[cfg(not(target_arch = "wasm32"))]
+pub enum HwDecoderAttempt {
+    /// This backend handled the video: a built decoder, or a real decode error.
+    Handled(Result<Box<dyn AsyncDecoder>>),
+    /// This backend does not handle this video (wrong codec, no device, ...). The
+    /// output sender is handed back so `new_decoder` can try the next backend or
+    /// the built-in software fallback.
+    NotSupported(crate::Sender<FrameResult>),
+}
+
+/// A factory that may build a hardware [`AsyncDecoder`] for a video, or decline.
+/// Register one with [`register_hw_video_decoder`].
+#[cfg(not(target_arch = "wasm32"))]
+pub type HwVideoDecoderFactory = std::sync::Arc<
+    dyn Fn(&str, &VideoDataDescription, &DecodeSettings, crate::Sender<FrameResult>) -> HwDecoderAttempt
+        + Send
+        + Sync,
+>;
+
+#[cfg(not(target_arch = "wasm32"))]
+static HW_DECODER_BACKENDS: std::sync::Mutex<Vec<HwVideoDecoderFactory>> =
+    std::sync::Mutex::new(Vec::new());
+
+/// Register a hardware-decode backend. [`new_decoder`] consults registered
+/// backends (in registration order) BEFORE the built-in software decoders, so an
+/// out-of-tree crate (a Vulkan Video / VideoToolbox / NVDEC backend, ...) can
+/// supply hardware decoding without `re_video` depending on it. Each factory
+/// either handles the video ([`HwDecoderAttempt::Handled`]) or hands the sender
+/// back ([`HwDecoderAttempt::NotSupported`]) so the search continues.
+#[cfg(not(target_arch = "wasm32"))]
+pub fn register_hw_video_decoder(factory: HwVideoDecoderFactory) {
+    HW_DECODER_BACKENDS
+        .lock()
+        .expect("hw decoder registry lock")
+        .push(factory);
+}
+
+/// Try each registered hardware backend in turn. `Ok(result)` if one handled the
+/// video (the result may itself be a decode error); `Err(sender)` if none did,
+/// returning the sender for the software fallback.
+#[cfg(not(target_arch = "wasm32"))]
+fn try_hw_video_decoder(
+    debug_name: &str,
+    video: &VideoDataDescription,
+    decode_settings: &DecodeSettings,
+    mut output_sender: crate::Sender<FrameResult>,
+) -> std::result::Result<Result<Box<dyn AsyncDecoder>>, crate::Sender<FrameResult>> {
+    // Snapshot the factories so the registry lock is not held while a factory
+    // opens a GPU device (which can be slow).
+    let backends: Vec<HwVideoDecoderFactory> = HW_DECODER_BACKENDS
+        .lock()
+        .expect("hw decoder registry lock")
+        .clone();
+    for factory in backends {
+        match factory(debug_name, video, decode_settings, output_sender) {
+            HwDecoderAttempt::Handled(result) => return Ok(result),
+            HwDecoderAttempt::NotSupported(sender) => output_sender = sender,
+        }
+    }
+    Err(output_sender)
+}

diff --git a/crates/viewer/re_renderer/tests/g2g_tier_b_render.rs b/crates/viewer/re_renderer/tests/g2g_tier_b_render.rs
new file mode 100644
index 000000000..bddd36005
--- /dev/null
+++ b/crates/viewer/re_renderer/tests/g2g_tier_b_render.rs
@@ -0,0 +1,225 @@
+//! Tier B last mile: a real `.mp4` is hardware-decoded by glass2glass straight
+//! into a GPU-resident `wgpu::Texture` (via `re_video::new_decoder` in GPU-texture
+//! mode, YUV->RGB already applied on the decode device), and that texture is then
+//! **consumed inside `re_renderer`**: adopted into re_renderer's texture pool with
+//! no copy, drawn by re_renderer's real rectangle renderer into an offscreen view,
+//! and the RENDER OUTPUT is read back to prove re_renderer actually sampled the
+//! decoded texture. No CPU pixel copy happens between decode and render.
+//!
+//! This closes the wgpu-texture wedge end to end: g2g decodes on the GPU and
+//! re_renderer renders that texture directly, on the SAME device (g2g creates the
+//! decode device; re_renderer's `RenderContext` is built on the carried
+//! `GpuContext`, the correct direction, see the PoC README device-identity note).
+//!
+//! Runs on the RTX 3060; skips gracefully with no Vulkan H.264 decode adapter or no
+//! compute queue (the GPU-texture path needs a distinct compute family).
+#![cfg(all(not(target_arch = "wasm32"), feature = "gpu-textures"))]
+
+use std::time::Duration;
+
+use re_renderer::renderer::{ColormappedTexture, RectangleDrawData, RectangleOptions, TexturedRect};
+use re_renderer::resource_managers::GpuTexture2D;
+use re_renderer::view_builder::{
+    OrthographicCameraMode, Projection, TargetConfiguration, ViewBuilder,
+};
+use re_renderer::{
+    AlphaChannelUsage, MsaaMode, RenderConfig, RenderContext, ScreenshotProcessor,
+};
+use re_video::player::VideoSliceSource;
+use re_video::{
+    DecodeError, DecodeSettings, SampleMetadataState, VideoCodec, VideoDataDescription, new_decoder,
+};
+
+const MP4: &[u8] =
+    include_bytes!("../../../utils/re_video/tests/fixtures/h264_640x480.mp4");
+const W: u32 = 640;
+const H: u32 = 480;
+const READBACK_ID: re_renderer::GpuReadbackIdentifier = 0xB;
+
+/// Decode the first GPU-resident frame of the fixture through the real `re_video`
+/// crate with the g2g backend. Returns `None` if no decode device is available
+/// (the test then skips). Keeps the decoder alive in the returned tuple so the
+/// texture's device outlives the render.
+fn decode_first_gpu_frame() -> Option<(re_video::Frame, Box<dyn re_video::AsyncDecoder>)> {
+    re_video_g2g::register();
+    re_video_g2g::set_prefer_gpu_textures(true);
+
+    let video = VideoDataDescription::load_mp4(MP4, "g2g-tier-b").expect("demux mp4");
+    assert_eq!(video.codec, VideoCodec::H264);
+
+    let (sender, receiver) = re_video::channel("g2g-tier-b");
+    let mut decoder = match new_decoder("g2g-tier-b", &video, &DecodeSettings::default(), sender) {
+        Ok(d) => d,
+        Err(err) => {
+            eprintln!("skip g2g_tier_b_render: new_decoder unavailable: {err}");
+            return None;
+        }
+    };
+
+    let source = VideoSliceSource(MP4);
+    for (sample_idx, state) in video.samples.iter_indexed() {
+        let SampleMetadataState::Present(sample) = state else {
+            continue;
+        };
+        let chunk = sample.get(&source, sample_idx).expect("sample bytes");
+        decoder.submit_chunk(chunk).expect("submit chunk");
+    }
+    decoder.end_of_video().expect("end of video");
+
+    loop {
+        match receiver.recv_timeout(Duration::from_secs(20)) {
+            Ok(Ok(frame)) => return Some((frame, decoder)),
+            // No adapter / no distinct compute queue for the GPU-resident path.
+            Ok(Err(DecodeError::HwDecoder(msg)))
+                if msg.contains("open decode device") || msg.contains("NoComputeQueue") =>
+            {
+                eprintln!("skip g2g_tier_b_render: {msg}");
+                return None;
+            }
+            Ok(Err(err)) => panic!("decode error: {err}"),
+            Err(_) => panic!("no frame within timeout"),
+        }
+    }
+}
+
+#[test]
+fn g2g_decoded_texture_is_rendered_by_re_renderer() {
+    let Some((frame, _decoder)) = decode_first_gpu_frame() else {
+        return; // skipped (no device); message already printed.
+    };
+
+    let gpu = frame
+        .content
+        .gpu_texture
+        .as_ref()
+        .expect("frame carries a GPU texture (Tier B mode)");
+    assert!(frame.content.data.is_empty(), "GPU-mode frame must not be read back in decode");
+    assert_eq!(gpu.texture.width(), W);
+    assert_eq!(gpu.texture.height(), H);
+
+    // Ground truth: what the g2g texture actually contains (verification-only
+    // readback, NOT part of the render path). re_renderer's output must match this.
+    let expected = gpu.read_rgba();
+    assert_eq!(expected.len() as u32, W * H * 4);
+
+    // Build re_renderer ON THE DECODE DEVICE (the carried GpuContext). This is the
+    // device-identity constraint: g2g owns the decode device, so the renderer runs
+    // on it, not the reverse.
+    let mut ctx = RenderContext::new(
+        &gpu.adapter,
+        gpu.device.clone(),
+        gpu.queue.clone(),
+        wgpu::TextureFormat::Rgba8Unorm,
+        // MSAA off for an exact 1:1 texel->pixel comparison against `expected`.
+        |_caps| RenderConfig { msaa_mode: MsaaMode::Off },
+    )
+    .expect("build RenderContext on the g2g decode device");
+
+    // Adopt the hardware-decoded texture into re_renderer WITHOUT a copy, wrap it as
+    // an RGBA rectangle texture (linear passthrough: the g2g texture is already
+    // BT.601 RGB in Rgba8Unorm, so disable the sRGB decode `from_unorm_rgba` assumes).
+    let adopted = ctx
+        .gpu_resources
+        .textures
+        .adopt_external_texture(gpu.texture.clone(), "g2g-decoded-frame".into());
+    let tex2d = GpuTexture2D::new(adopted, AlphaChannelUsage::Opaque)
+        .expect("adopted texture is 2D");
+    let mut colormapped = ColormappedTexture::from_unorm_rgba(tex2d);
+    colormapped.decode_srgb = false;
+
+    // A screen-filling rectangle in a top-left-origin orthographic view, so world
+    // coordinates map 1:1 to pixels (see OrthographicCameraMode docs).
+    let rect = TexturedRect {
+        top_left_corner_position: glam::vec3(0.0, 0.0, 0.0),
+        extent_u: glam::vec3(W as f32, 0.0, 0.0),
+        extent_v: glam::vec3(0.0, H as f32, 0.0),
+        colormapped_texture: colormapped,
+        options: RectangleOptions::default(),
+    };
+    let rect_draw = RectangleDrawData::new(&ctx, &[rect]).expect("build rectangle draw data");
+
+    // Render the frame to an offscreen view and schedule a screenshot of the result.
+    let target_cfg = TargetConfiguration {
+        name: "g2g-tier-b".into(),
+        resolution_in_pixel: [W, H],
+        view_from_world: macaw::IsoTransform::from_rotation_translation(
+            glam::Quat::IDENTITY,
+            glam::Vec3::ZERO,
+        ),
+        projection_from_view: Projection::Orthographic {
+            camera_mode: OrthographicCameraMode::TopLeftCornerAndExtendZ,
+            vertical_world_size: H as f32,
+            far_plane_distance: 1000.0,
+        },
+        ..Default::default()
+    };
+
+    ctx.begin_frame();
+    let mut view_builder = ViewBuilder::new(&ctx, target_cfg).expect("view builder");
+    view_builder
+        .schedule_screenshot(&ctx, READBACK_ID, ())
+        .expect("schedule screenshot");
+    view_builder.queue_draw(&ctx, rect_draw);
+    let command_buffer = view_builder
+        .draw(&ctx, re_renderer::Rgba::TRANSPARENT)
+        .expect("draw view");
+    ctx.before_submit();
+    ctx.queue.submit([command_buffer]);
+    // Wait for the render + screenshot copy-to-staging-buffer to finish on the GPU.
+    ctx.device
+        .poll(wgpu::PollType::Wait { submission_index: None, timeout: Some(Duration::from_secs(10)) })
+        .expect("poll GPU (render)");
+    // The next frame schedules `map_async` on the readback staging buffers
+    // (RenderContext::begin_frame -> GpuReadbackBelt::after_queue_submit)...
+    ctx.begin_frame();
+    // ...and this second poll drives those map callbacks to completion so the data
+    // is available to `next_readback_result` below.
+    ctx.device
+        .poll(wgpu::PollType::Wait { submission_index: None, timeout: Some(Duration::from_secs(10)) })
+        .expect("poll GPU (map readback)");
+
+    // Retrieve the rendered output.
+    let mut screenshot: Option<Vec<u8>> = None;
+    ScreenshotProcessor::next_readback_result::<()>(&ctx, READBACK_ID, |data, extent, ()| {
+        assert_eq!(extent.x, W);
+        assert_eq!(extent.y, H);
+        screenshot = Some(data.to_vec());
+    });
+    let screenshot = screenshot.expect("re_renderer produced a screenshot of the g2g texture");
+    assert_eq!(screenshot.len() as u32, W * H * 4);
+
+    // The render output must be a real picture (not a cleared/blank target).
+    let min = *screenshot.iter().min().unwrap();
+    let max = *screenshot.iter().max().unwrap();
+    assert!(min <= 20 && max >= 200, "render output range {min}..={max} is not a real picture");
+
+    // And it must match what the g2g texture actually held: re_renderer sampled THAT
+    // texture. Compare the interior (skip a 2px border to avoid any edge coverage) on
+    // RGB; with MSAA off + nearest 1:1 mapping + linear passthrough this is near-exact.
+    let mut sum = 0u64;
+    let mut n = 0u64;
+    for y in 2..(H - 2) {
+        for x in 2..(W - 2) {
+            let o = ((y * W + x) * 4) as usize;
+            for c in 0..3 {
+                sum += (screenshot[o + c] as i32 - expected[o + c] as i32).unsigned_abs() as u64;
+                n += 1;
+            }
+        }
+    }
+    let mean = sum as f64 / n as f64;
+    // Near-exact: the only residual is sub-texel nearest sampling at high-frequency
+    // edges (MSAA is off, mapping is 1:1). A wrong/blank/shifted render would differ
+    // by tens or hundreds, so this margin still uniquely pins "re_renderer sampled
+    // THIS texture" (same <6 tolerance the sibling g2g_gpu_texture test uses).
+    assert!(
+        mean < 6.0,
+        "re_renderer render output mean abs diff {mean:.2} vs the g2g texture's own contents too large",
+    );
+
+    eprintln!(
+        "g2g_tier_b_render: g2g-decoded wgpu::Texture adopted + rendered by re_renderer's \
+         rectangle renderer (offscreen, on the decode device), render output matches the \
+         decoded texture (interior mean abs diff {mean:.2})"
+    );
+}

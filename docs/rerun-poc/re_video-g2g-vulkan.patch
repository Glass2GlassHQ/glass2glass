index 000000000..a6cc732c4
--- /dev/null
+++ b/crates/utils/re_video_g2g/src/lib.rs
@@ -0,0 +1,417 @@
+//! glass2glass Vulkan Video hardware decoder as a `re_video` decode backend.
+//!
+//! This crate is the out-of-tree implementer of `re_video`'s hardware-decode
+//! extension point: it registers a factory (via [`register`]) with
+//! [`re_video::register_hw_video_decoder`], and `re_video::new_decoder` then prefers
+//! it over its built-in software decoders. Crucially, `re_video` has NO dependency
+//! on this crate or on glass2glass; the coupling is one-directional.
+//!
+//! It offers two output tiers of the wgpu-texture wedge:
+//! * **Tier A (readback):** g2g decodes H.264 / H.265 / AV1 entirely on the GPU
+//!   (vendor-neutral Vulkan Video), reads the frame back as packed I420, and hands
+//!   it to `re_video`, which uploads it and does YUV->RGB in `re_renderer`.
+//! * **Tier B (zero-copy):** g2g keeps the frame GPU-resident and hands `re_video`
+//!   the decoded `wgpu::Texture` directly (YUV->RGB already applied on the decode
+//!   device) as a [`re_video::GpuVideoFrame`] on `FrameContent::gpu_texture`. A
+//!   consumer renders it with no CPU readback and no colour convert. Selected with
+//!   [`set_prefer_gpu_textures`].
+//!
+//! The decode itself is a thin map: [`g2g_plugins::revideo::VulkanStreamDecoder`]
+//! already produces frames in re_video's native packed-I420 layout (with the same
+//! range / matrix-coefficient enums), so this file only translates types and
+//! carries the per-chunk timing metadata into [`re_video::FrameInfo`].
+//!
+//! ## Threading
+//!
+//! The decoder runs on its own OS thread, fed by a command channel, so
+//! `submit_chunk` returns immediately (the async contract Rerun's player expects)
+//! and frames arrive on the output channel as they decode. Unlike re_video's
+//! built-in `SyncDecoderWrapper` (whose `Drop` fires-and-forgets its thread), this
+//! decoder JOINS its worker on `Drop`, so all Vulkan/wgpu teardown completes on the
+//! worker thread before `Drop` returns. That is the fix for the double-free the
+//! M509 PoC hit: g2g's decoder is safe to create/decode/drop on a worker thread
+//! (verified), but the built-in wrapper's detached thread raced its Vulkan teardown
+//! against process exit.
+
+use std::sync::Mutex;
+use std::sync::mpsc::{Receiver, Sender as CmdSender};
+use std::thread::JoinHandle;
+
+use g2g_core::runtime::block_on;
+use g2g_plugins::gpu::GpuContext;
+use g2g_plugins::revideo::{
+    CodecConfig, DecodedVideoFrame, DecodedVideoTexture, VideoCodec as G2gCodec, VideoColorRange,
+    VideoMatrixCoefficients, VideoPixelLayout, VulkanStreamDecoder,
+};
+use g2g_plugins::vulkanvideo::{
+    open_av1_decode_device, open_h264_decode_device, open_h265_decode_device,
+};
+use re_mp4::StsdBoxContent;
+
+use re_video::{
+    AsyncDecoder, Chunk, DecodeError, DecodeResult, DecodeSettings, Frame, FrameContent, FrameInfo,
+    FrameResult, GpuVideoFrame, HwDecoderAttempt, PixelFormat, Sender, VideoCodec,
+    VideoDataDescription, YuvMatrixCoefficients, YuvPixelLayout, YuvRange,
+};
+
+/// Register this backend with `re_video`. After calling this, `re_video::new_decoder`
+/// prefers g2g's hardware Vulkan Video decoder for H.264 / H.265 / AV1 whenever a
+/// decode device is available, falling back to re_video's software path otherwise.
+/// Call once at startup (registering twice just adds a redundant, harmless factory).
+pub fn register() {
+    re_video::register_hw_video_decoder(std::sync::Arc::new(
+        |debug_name: &str,
+         video: &VideoDataDescription,
+         _decode_settings: &DecodeSettings,
+         output_sender: Sender<FrameResult>| {
+            // Decline codecs g2g's Vulkan path doesn't cover (VP8/VP9/images), so
+            // re_video uses its own decoder for those.
+            let Some(codec) = supported_codec(&video.codec) else {
+                return HwDecoderAttempt::NotSupported(output_sender);
+            };
+            // Decline if no Vulkan decode device opens (e.g. CI, wrong GPU): hand the
+            // sender back so re_video falls back to ffmpeg / dav1d rather than erroring.
+            if !can_open_device(codec) {
+                return HwDecoderAttempt::NotSupported(output_sender);
+            }
+            let config = extract_config(video);
+            let decoder = G2gVulkanDecoder::new(debug_name.to_owned(), codec, config, output_sender);
+            HwDecoderAttempt::Handled(Ok(Box::new(decoder)))
+        },
+    ));
+}
+
+/// Map a re_video codec onto the g2g Vulkan codec, or `None` if g2g's Vulkan Video
+/// path doesn't cover it (VP8 / VP9 / image sequences).
+fn supported_codec(codec: &VideoCodec) -> Option<G2gCodec> {
+    match codec {
+        VideoCodec::H264 => Some(G2gCodec::H264),
+        VideoCodec::H265 => Some(G2gCodec::H265),
+        VideoCodec::AV1 => Some(G2gCodec::Av1),
+        VideoCodec::VP8 | VideoCodec::VP9 | VideoCodec::ImageSequence(_) => None,
+    }
+}
+
+/// g2g codec configuration extracted from a container's sample-entry (`stsd`) box,
+/// owned so it can cross to the decode thread. `None` for a raw Annex-B / OBU
+/// elementary stream (no `stsd`), where the decoder takes its parameters in-band
+/// from the first chunk instead.
+enum OwnedConfig {
+    Avcc(Vec<u8>),
+    Hvcc(Vec<u8>),
+    Av1c(Vec<u8>),
+}
+
+impl OwnedConfig {
+    fn as_codec_config(&self) -> CodecConfig<'_> {
+        match self {
+            Self::Avcc(b) => CodecConfig::Avcc(b),
+            Self::Hvcc(b) => CodecConfig::Hvcc(b),
+            Self::Av1c(b) => CodecConfig::Av1c(b),
+        }
+    }
+}
+
+/// Extract the out-of-band codec configuration record (`avcC` / `hvcC` / `av1C`)
+/// from a video's `stsd` box, if present. Its presence means the samples are the
+/// container's stored form (length-prefixed AVCC for H.26x), which the g2g decoder
+/// reframes; absent (a raw elementary stream) means in-band parameters from the
+/// first chunk. `.raw` is the config record body (no box header), exactly what
+/// `VulkanStreamDecoder::from_config` parses.
+fn extract_config(video: &VideoDataDescription) -> Option<OwnedConfig> {
+    let stsd = video.encoding_details.as_ref()?.stsd.as_ref()?;
+    match &stsd.contents {
+        StsdBoxContent::Avc1(c) => Some(OwnedConfig::Avcc(c.avcc.raw.clone())),
+        StsdBoxContent::Hvc1(c) | StsdBoxContent::Hev1(c) => {
+            Some(OwnedConfig::Hvcc(c.hvcc.raw.clone()))
+        }
+        StsdBoxContent::Av01(c) => Some(OwnedConfig::Av1c(c.av1c.raw.clone())),
+        _ => None,
+    }
+}
+
+/// Whether g2g can open a Vulkan Video decode device for `codec` right now. Used by
+/// [`register`]'s factory to fall back to re_video's software path (ffmpeg / dav1d)
+/// when there is no usable hardware decoder, rather than committing to this backend
+/// and erroring the stream. A synchronous capability probe: opens and immediately
+/// drops a device on the calling thread (the worker opens its own for decoding).
+fn can_open_device(codec: G2gCodec) -> bool {
+    match codec {
+        G2gCodec::H264 => block_on(open_h264_decode_device()).is_ok(),
+        G2gCodec::H265 => block_on(open_h265_decode_device()).is_ok(),
+        G2gCodec::Av1 => block_on(open_av1_decode_device()).is_ok(),
+    }
+}
+
+static PREFER_GPU_TEXTURES: std::sync::atomic::AtomicBool =
+    std::sync::atomic::AtomicBool::new(false);
+
+/// Opt subsequently-created g2g decoders into Tier B (GPU-resident RGBA texture)
+/// output instead of Tier A (CPU I420). Off by default. This is a PoC selector: a
+/// real integration would negotiate it from re_renderer's frame-consumption path
+/// (which device it renders on), since zero-copy only pays off when re_renderer
+/// runs on the decode device this backend exposes.
+pub fn set_prefer_gpu_textures(enabled: bool) {
+    PREFER_GPU_TEXTURES.store(enabled, std::sync::atomic::Ordering::Relaxed);
+}
+
+fn gpu_textures_enabled() -> bool {
+    PREFER_GPU_TEXTURES.load(std::sync::atomic::Ordering::Relaxed)
+}
+
+/// Command sent to the decode thread.
+enum Command {
+    /// Decode one coded sample and emit its frame(s).
+    Chunk(Chunk),
+    /// Clear the reference state (seek): the next chunk must be a keyframe.
+    Reset,
+    /// Finish and drop the decoder.
+    Stop,
+}
+
+/// A re_video `AsyncDecoder` backed by g2g's hardware Vulkan Video decoder, running
+/// on a dedicated joined-on-drop worker thread.
+struct G2gVulkanDecoder {
+    debug_name: String,
+    // A `std::sync::mpsc::Sender` is `Send` but not `Sync`; `AsyncDecoder` requires
+    // `Send + Sync`, so guard it. Access is only ever `&mut self`, so the lock is
+    // uncontended.
+    commands: Mutex<CmdSender<Command>>,
+    worker: Option<JoinHandle<()>>,
+}
+
+impl core::fmt::Debug for G2gVulkanDecoder {
+    fn fmt(&self, f: &mut core::fmt::Formatter<'_>) -> core::fmt::Result {
+        f.debug_struct("G2gVulkanDecoder")
+            .field("debug_name", &self.debug_name)
+            .field("running", &self.worker.is_some())
+            .finish_non_exhaustive()
+    }
+}
+
+impl G2gVulkanDecoder {
+    fn new(
+        debug_name: String,
+        codec: G2gCodec,
+        config: Option<OwnedConfig>,
+        output_sender: Sender<FrameResult>,
+    ) -> Self {
+        let (tx, rx) = std::sync::mpsc::channel::<Command>();
+        let name = debug_name.clone();
+        let worker = std::thread::Builder::new()
+            .name(format!("g2g-vulkan-decode:{debug_name}"))
+            .spawn(move || decode_thread(name, codec, config, rx, output_sender))
+            .expect("spawn g2g vulkan decode thread");
+        Self { debug_name, commands: Mutex::new(tx), worker: Some(worker) }
+    }
+
+    fn send(&self, cmd: Command) {
+        // The worker only stops on `Command::Stop` (sent from `Drop`), so the
+        // channel is open here; a send error would only mean the worker panicked,
+        // in which case dropping the command is fine.
+        let _ = self.commands.lock().expect("command lock").send(cmd);
+    }
+}
+
+impl AsyncDecoder for G2gVulkanDecoder {
+    fn submit_chunk(&mut self, chunk: Chunk) -> DecodeResult<()> {
+        // Non-blocking: hand the sample to the decode thread.
+        self.send(Command::Chunk(chunk));
+        Ok(())
+    }
+
+    fn reset(&mut self, _video_data_description: &VideoDataDescription) -> DecodeResult<()> {
+        self.send(Command::Reset);
+        Ok(())
+    }
+}
+
+impl Drop for G2gVulkanDecoder {
+    fn drop(&mut self) {
+        // Ask the worker to stop, then JOIN it: its `VulkanStreamDecoder` (device,
+        // session, DPB, all Vulkan/wgpu objects) is dropped on the worker thread, and
+        // joining guarantees that teardown finishes before this returns, so it never
+        // races process/loader exit. This is the teardown fix.
+        self.send(Command::Stop);
+        if let Some(worker) = self.worker.take() {
+            let _ = worker.join();
+        }
+    }
+}
+
+/// The decode thread: lazily builds the decoder from the first chunk (the keyframe
+/// carries the SPS/PPS or AV1 sequence header in-band), then decodes each chunk and
+/// sends frames on the output channel. Returns (dropping the decoder) on `Stop` or
+/// when the command channel closes.
+fn decode_thread(
+    debug_name: String,
+    codec: G2gCodec,
+    config: Option<OwnedConfig>,
+    commands: Receiver<Command>,
+    output: Sender<FrameResult>,
+) {
+    let gpu_mode = gpu_textures_enabled();
+    let mut inner: Option<VulkanStreamDecoder> = None;
+    while let Ok(cmd) = commands.recv() {
+        match cmd {
+            Command::Chunk(chunk) => {
+                if inner.is_none() {
+                    match build_decoder(codec, config.as_ref(), &chunk.data, gpu_mode, &debug_name) {
+                        Ok(dec) => inner = Some(dec),
+                        Err(err) => {
+                            output.send(Err(err)).ok();
+                            continue;
+                        }
+                    }
+                }
+                let dec = inner.as_mut().expect("decoder initialized");
+                if gpu_mode {
+                    // Tier B: emit GPU-resident RGBA textures, no CPU readback.
+                    match dec.submit_chunk_texture(&chunk.data, chunk.is_sync) {
+                        Ok(textures) => {
+                            let ctx = dec.gpu_context();
+                            for texture in textures {
+                                output.send(Ok(to_gpu_frame(texture, &ctx, &chunk))).ok();
+                            }
+                        }
+                        Err(err) => {
+                            output
+                                .send(Err(DecodeError::HwDecoder(format!(
+                                    "{debug_name}: gpu decode: {err:?}"
+                                ))))
+                                .ok();
+                        }
+                    }
+                } else {
+                    match dec.submit_chunk(&chunk.data, chunk.is_sync) {
+                        Ok(frames) => {
+                            for frame in frames {
+                                output.send(Ok(to_frame(frame, &chunk))).ok();
+                            }
+                        }
+                        Err(err) => {
+                            output
+                                .send(Err(DecodeError::HwDecoder(format!(
+                                    "{debug_name}: decode: {err:?}"
+                                ))))
+                                .ok();
+                        }
+                    }
+                }
+            }
+            Command::Reset => {
+                if let Some(dec) = &mut inner {
+                    if let Err(err) = dec.reset() {
+                        output
+                            .send(Err(DecodeError::HwDecoder(format!(
+                                "{debug_name}: reset: {err:?}"
+                            ))))
+                            .ok();
+                    }
+                }
+            }
+            Command::Stop => break,
+        }
+    }
+    // `inner` drops here, on this worker thread, before it exits.
+}
+
+/// Open the decode device and build the stream decoder. With an out-of-band
+/// container `config` (MP4 `avcC` / `hvcC` / `av1C`), build from that and let the
+/// decoder reframe the length-prefixed samples; otherwise take the parameters
+/// in-band from the first coded sample (`init`, a raw Annex-B / OBU stream). Runs on
+/// the decode thread.
+fn build_decoder(
+    codec: G2gCodec,
+    config: Option<&OwnedConfig>,
+    init: &[u8],
+    gpu: bool,
+    debug_name: &str,
+) -> DecodeResult<VulkanStreamDecoder> {
+    let device = match codec {
+        G2gCodec::H264 => block_on(open_h264_decode_device()),
+        G2gCodec::H265 => block_on(open_h265_decode_device()),
+        G2gCodec::Av1 => block_on(open_av1_decode_device()),
+    }
+    .map_err(|e| DecodeError::HwDecoder(format!("{debug_name}: open decode device: {e:?}")))?;
+    match config {
+        // `gpu` selects GPU-texture output (Tier B) over CPU I420 (Tier A).
+        Some(cfg) => VulkanStreamDecoder::from_config(device, cfg.as_codec_config(), gpu)
+            .map_err(|e| {
+                DecodeError::HwDecoder(format!("{debug_name}: build decoder from config: {e:?}"))
+            }),
+        None if gpu => VulkanStreamDecoder::new_gpu(device, codec, init)
+            .map_err(|e| DecodeError::HwDecoder(format!("{debug_name}: build gpu decoder: {e:?}"))),
+        None => VulkanStreamDecoder::new(device, codec, init)
+            .map_err(|e| DecodeError::HwDecoder(format!("{debug_name}: build decoder: {e:?}"))),
+    }
+}
+
+/// Translate a g2g [`DecodedVideoFrame`] and its source [`Chunk`] into a re_video
+/// [`Frame`]. The pixel data is moved, not copied.
+fn to_frame(frame: DecodedVideoFrame, chunk: &Chunk) -> Frame {
+    let layout = match frame.layout {
+        VideoPixelLayout::Y_U_V444 => YuvPixelLayout::Y_U_V444,
+        VideoPixelLayout::Y_U_V422 => YuvPixelLayout::Y_U_V422,
+        VideoPixelLayout::Y_U_V420 => YuvPixelLayout::Y_U_V420,
+        VideoPixelLayout::Y400 => YuvPixelLayout::Y400,
+    };
+    let range = match frame.range {
+        VideoColorRange::Limited => YuvRange::Limited,
+        VideoColorRange::Full => YuvRange::Full,
+    };
+    let coefficients = match frame.coefficients {
+        VideoMatrixCoefficients::Identity => YuvMatrixCoefficients::Identity,
+        VideoMatrixCoefficients::Bt601 => YuvMatrixCoefficients::Bt601,
+        VideoMatrixCoefficients::Bt709 => YuvMatrixCoefficients::Bt709,
+    };
+
+    Frame {
+        content: FrameContent {
+            data: frame.data,
+            width: frame.width,
+            height: frame.height,
+            format: PixelFormat::Yuv { layout, range, coefficients },
+            gpu_texture: None,
+        },
+        info: frame_info(chunk),
+    }
+}
+
+/// Translate a GPU-resident [`DecodedVideoTexture`] (Tier B) and its source [`Chunk`]
+/// into a re_video [`Frame`]: the RGBA texture rides on `FrameContent::gpu_texture`
+/// as a generic [`GpuVideoFrame`] and `data` is left empty (never read back). The
+/// decode device's wgpu handles (a cheap Arc-clone) travel with the frame so a
+/// consumer can render the texture on the right device.
+fn to_gpu_frame(texture: DecodedVideoTexture, ctx: &GpuContext, chunk: &Chunk) -> Frame {
+    Frame {
+        content: FrameContent {
+            data: Vec::new(),
+            width: texture.width,
+            height: texture.height,
+            // Already RGBA (g2g's ycbcr compute pass ran); the consumer uses the
+            // texture, not `data`, so no YUV colour metadata is needed.
+            format: PixelFormat::Rgba8Unorm,
+            gpu_texture: Some(GpuVideoFrame {
+                texture: texture.texture,
+                device: ctx.device.clone(),
+                queue: ctx.queue.clone(),
+                adapter: ctx.adapter.clone(),
+            }),
+        },
+        info: frame_info(chunk),
+    }
+}
+
+/// The per-frame timing metadata carried from a source [`Chunk`], shared by the CPU
+/// and GPU frame builders.
+fn frame_info(chunk: &Chunk) -> FrameInfo {
+    FrameInfo {
+        is_sync: Some(chunk.is_sync),
+        sample_idx: Some(chunk.sample_idx),
+        frame_nr: Some(chunk.frame_nr),
+        presentation_timestamp: chunk.presentation_timestamp,
+        duration: chunk.duration,
+        latest_decode_timestamp: Some(chunk.decode_timestamp),
+    }
+}
diff --git a/crates/utils/re_video_g2g/tests/gpu_texture.rs b/crates/utils/re_video_g2g/tests/gpu_texture.rs
new file mode 100644
index 000000000..512064fce
--- /dev/null
+++ b/crates/utils/re_video_g2g/tests/gpu_texture.rs
@@ -0,0 +1,159 @@
+//! Tier B (zero-copy) end-to-end: an `.mp4` decoded through re_video's public API
+//! with glass2glass' hardware Vulkan Video backend in **GPU-texture mode**, so each
+//! `Frame` arrives GPU-resident (`FrameContent::gpu_texture`, a generic
+//! `re_video::GpuVideoFrame`) with NO CPU readback in the decode path. This is the
+//! moat the wgpu-texture wedge is about: g2g decodes on the GPU and hands re_video a
+//! `wgpu::Texture` (YUV->RGB already applied), skipping both the readback and
+//! re_renderer's own upload + colour convert.
+//!
+//! The backend emits GPU frames when `set_prefer_gpu_textures(true)` is called (a
+//! PoC selector; a real integration negotiates it from which device re_renderer
+//! renders on). The frame carries the decode device's wgpu handles, so a consumer
+//! renders on the right device; here the test reads the texture back only to VERIFY
+//! it, anchoring to the software ffmpeg reference via the same BT.601-limited matrix
+//! g2g's ycbcr compute pass uses.
+//!
+//! Runs on the RTX 3060; skips with no Vulkan H.264 decode adapter / no compute queue.
+#![cfg(not(target_arch = "wasm32"))]
+
+use std::time::Duration;
+
+use re_video::player::VideoSliceSource;
+use re_video::{
+    DecodeError, DecodeSettings, PixelFormat, SampleMetadataState, VideoCodec, VideoDataDescription,
+    new_decoder,
+};
+
+const MP4: &[u8] = include_bytes!("../../re_video/tests/fixtures/h264_640x480.mp4");
+const REF: &[u8] = include_bytes!("../../re_video/tests/fixtures/h264_640x480_ref.yuv");
+const W: usize = 640;
+const H: usize = 480;
+const N_FRAMES: usize = 10;
+
+/// BT.601 limited-range YUV -> RGBA, matching g2g's `VkSamplerYcbcrConversion`
+/// (`YCBCR_601`, `ITU_NARROW`). Used to reconstruct an RGBA reference from the
+/// (bit-exact) software I420 so the GPU compute-pass output can be checked.
+fn i420_to_rgba_bt601(i420: &[u8]) -> Vec<u8> {
+    let cw = W / 2;
+    let y = &i420[..W * H];
+    let u = &i420[W * H..W * H + cw * (H / 2)];
+    let v = &i420[W * H + cw * (H / 2)..];
+    let mut out = vec![0u8; W * H * 4];
+    for row in 0..H {
+        for col in 0..W {
+            let yy = (y[row * W + col] as f32 - 16.0) * (255.0 / 219.0);
+            let cb = u[(row / 2) * cw + col / 2] as f32 - 128.0;
+            let cr = v[(row / 2) * cw + col / 2] as f32 - 128.0;
+            let o = (row * W + col) * 4;
+            out[o] = (yy + 1.596 * cr).clamp(0.0, 255.0) as u8;
+            out[o + 1] = (yy - 0.391 * cb - 0.813 * cr).clamp(0.0, 255.0) as u8;
+            out[o + 2] = (yy + 2.018 * cb).clamp(0.0, 255.0) as u8;
+            out[o + 3] = 255;
+        }
+    }
+    out
+}
+
+#[test]
+fn h264_mp4_decodes_to_gpu_textures_through_re_video() {
+    re_video_g2g::register();
+    // Select Tier B (GPU-texture) output before creating the decoder.
+    re_video_g2g::set_prefer_gpu_textures(true);
+
+    let video = VideoDataDescription::load_mp4(MP4, "g2g-gpu-poc").expect("demux mp4");
+    assert_eq!(video.codec, VideoCodec::H264);
+
+    let (sender, receiver) = re_video::channel("g2g-gpu-poc");
+    let mut decoder = match new_decoder("g2g-gpu-poc", &video, &DecodeSettings::default(), sender) {
+        Ok(d) => d,
+        Err(err) => {
+            eprintln!("skip gpu_texture: new_decoder unavailable: {err}");
+            return;
+        }
+    };
+
+    let source = VideoSliceSource(MP4);
+    for (sample_idx, state) in video.samples.iter_indexed() {
+        let SampleMetadataState::Present(sample) = state else {
+            continue;
+        };
+        let chunk = sample.get(&source, sample_idx).expect("sample bytes");
+        decoder.submit_chunk(chunk).expect("submit chunk");
+    }
+    decoder.end_of_video().expect("end of video");
+
+    let mut frames = Vec::new();
+    while frames.len() < N_FRAMES {
+        match receiver.recv_timeout(Duration::from_secs(20)) {
+            Ok(Ok(frame)) => frames.push(frame),
+            // No adapter, or no distinct compute queue for the GPU-resident path.
+            Ok(Err(DecodeError::HwDecoder(msg)))
+                if frames.is_empty()
+                    && (msg.contains("open decode device") || msg.contains("NoComputeQueue")) =>
+            {
+                eprintln!("skip gpu_texture: {msg}");
+                return;
+            }
+            Ok(Err(err)) => panic!("decode error after {} frames: {err}", frames.len()),
+            Err(_) => panic!("only got {} of {N_FRAMES} frames", frames.len()),
+        }
+    }
+
+    let i420_len = W * H + 2 * (W / 2) * (H / 2);
+    let mut readbacks = Vec::new();
+    for (i, frame) in frames.iter().enumerate() {
+        let c = &frame.content;
+        assert_eq!(c.width, W as u32, "frame {i} width");
+        assert_eq!(c.height, H as u32, "frame {i} height");
+        // The proof of zero-copy: the frame is GPU-resident and was NOT read back.
+        assert!(c.data.is_empty(), "frame {i}: GPU-mode frame must carry no CPU data");
+        assert!(matches!(c.format, PixelFormat::Rgba8Unorm), "frame {i} is RGBA");
+        let gpu = c.gpu_texture.as_ref().expect("frame carries a GPU texture");
+        assert_eq!(gpu.texture.width(), W as u32);
+        assert_eq!(gpu.texture.height(), H as u32);
+
+        // Verification only (never in the pipeline): read the texture back.
+        let rgba = gpu.read_rgba();
+        assert_eq!(rgba.len(), W * H * 4);
+        let min = *rgba.iter().min().unwrap();
+        let max = *rgba.iter().max().unwrap();
+        assert!(min <= 20 && max >= 200, "frame {i} RGBA range {min}..={max} not a real picture");
+        readbacks.push(rgba);
+    }
+
+    // Inter frames differ from their GOP's IDR (GPU DPB reference decode ran).
+    for gop_start in [0usize, 5] {
+        for p in 1..5 {
+            assert_ne!(
+                readbacks[gop_start + p], readbacks[gop_start],
+                "texture {} identical to its IDR; GPU reference decode failed",
+                gop_start + p
+            );
+        }
+    }
+
+    // Anchor correctness to the (bit-exact) software reference via the same matrix.
+    assert_eq!(REF.len(), i420_len * N_FRAMES);
+    let mut worst_mean = 0.0f64;
+    for (i, rgba) in readbacks.iter().enumerate() {
+        let expected = i420_to_rgba_bt601(&REF[i * i420_len..(i + 1) * i420_len]);
+        let mut sum = 0u64;
+        let mut n = 0u64;
+        for (j, (&g, &e)) in rgba.iter().zip(expected.iter()).enumerate() {
+            if j % 4 == 3 {
+                continue; // ignore alpha
+            }
+            sum += (g as i32 - e as i32).unsigned_abs() as u64;
+            n += 1;
+        }
+        let mean = sum as f64 / n as f64;
+        worst_mean = worst_mean.max(mean);
+        assert!(mean < 6.0, "frame {i}: GPU RGBA mean abs diff {mean:.2} vs BT.601(ffmpeg) too large");
+    }
+
+    eprintln!(
+        "gpu_texture: {N_FRAMES} GPU-resident RGBA textures from a real .mp4 via \
+         re_video::new_decoder, zero-copy (no CPU readback in decode); match ffmpeg \
+         (worst per-frame mean channel diff {worst_mean:.2})"
+    );
+}
diff --git a/crates/utils/re_video_g2g/tests/mp4_decode.rs b/crates/utils/re_video_g2g/tests/mp4_decode.rs
new file mode 100644
index 000000000..dfa130cf0
--- /dev/null
+++ b/crates/utils/re_video_g2g/tests/mp4_decode.rs
@@ -0,0 +1,108 @@
+//! End-to-end proof on a REAL container: an `.mp4` demuxed by re_video's own MP4
+//! demuxer (`VideoDataDescription::load_mp4`) and decoded through re_video's public
+//! decode API (`new_decoder` -> `AsyncDecoder::submit_chunk` -> frames), with
+//! glass2glass' hardware Vulkan Video decoder as the backend (registered via
+//! `re_video_g2g::register()`).
+//!
+//! This is the difference between "decodes our raw .h264 fixture" and "decodes what
+//! Rerun actually logs": the parameter sets come out of band from the `stsd`
+//! (`avcC`) box and the samples are length-prefixed (AVCC), not Annex-B. The g2g
+//! backend takes the `avcC` via `VulkanStreamDecoder::from_config` and reframes the
+//! samples itself. If no Vulkan H.264 decode device opens, `new_decoder` falls back
+//! to re_video's software path (here not compiled in, so it reports unsupported),
+//! which this test treats as a skip.
+//!
+//! Runs on the RTX 3060; every frame is checked bit-exact against a software ffmpeg
+//! `yuv420p` reference (the same reference the raw-elementary-stream test uses, so
+//! this also proves the remuxed container decodes identically).
+#![cfg(not(target_arch = "wasm32"))]
+
+use std::time::Duration;
+
+use re_video::player::VideoSliceSource;
+use re_video::{
+    DecodeError, DecodeSettings, PixelFormat, SampleMetadataState, VideoCodec, VideoDataDescription,
+    YuvPixelLayout, new_decoder,
+};
+
+const MP4: &[u8] = include_bytes!("../../re_video/tests/fixtures/h264_640x480.mp4");
+const REF: &[u8] = include_bytes!("../../re_video/tests/fixtures/h264_640x480_ref.yuv");
+const W: usize = 640;
+const H: usize = 480;
+const N_FRAMES: usize = 10;
+
+#[test]
+fn h264_mp4_decodes_through_re_video_with_g2g_backend() {
+    re_video_g2g::register();
+
+    // re_video's own MP4 demuxer produces the description + samples.
+    let video = VideoDataDescription::load_mp4(MP4, "g2g-mp4-poc").expect("demux mp4");
+    assert_eq!(video.codec, VideoCodec::H264);
+    let details = video.encoding_details.as_ref().expect("encoding details");
+    // The container path: params out of band in the stsd (avcC), samples AVCC.
+    assert!(details.stsd.is_some(), "mp4 sample entry carries an avcC (stsd) box");
+    assert_eq!(details.coded_dimensions, [W as u16, H as u16]);
+
+    let (sender, receiver) = re_video::channel("g2g-mp4-poc");
+    let mut decoder = match new_decoder("g2g-mp4-poc", &video, &DecodeSettings::default(), sender) {
+        Ok(d) => d,
+        // No Vulkan H.264 decode adapter and no software fallback compiled in.
+        Err(err) => {
+            eprintln!("skip mp4_decode: new_decoder unavailable: {err}");
+            return;
+        }
+    };
+
+    // Feed each MP4 sample as a chunk, exactly as the player's `get` builds them: the
+    // sample bytes are a byte-span into the original file.
+    let source = VideoSliceSource(MP4);
+    let mut n_samples = 0;
+    for (sample_idx, state) in video.samples.iter_indexed() {
+        let SampleMetadataState::Present(sample) = state else {
+            continue;
+        };
+        let chunk = sample.get(&source, sample_idx).expect("sample bytes");
+        decoder.submit_chunk(chunk).expect("submit chunk");
+        n_samples += 1;
+    }
+    assert_eq!(n_samples, N_FRAMES, "mp4 has 10 samples (frames)");
+    decoder.end_of_video().expect("end of video");
+
+    // Drain frames off re_video's output channel.
+    let mut frames = Vec::new();
+    while frames.len() < N_FRAMES {
+        match receiver.recv_timeout(Duration::from_secs(20)) {
+            Ok(Ok(frame)) => frames.push(frame),
+            Ok(Err(DecodeError::HwDecoder(msg)))
+                if frames.is_empty() && msg.contains("open decode device") =>
+            {
+                eprintln!("skip mp4_decode: {msg}");
+                return;
+            }
+            Ok(Err(err)) => panic!("decode error after {} frames: {err}", frames.len()),
+            Err(_) => panic!("only got {} of {N_FRAMES} frames", frames.len()),
+        }
+    }
+
+    let i420_len = W * H + 2 * (W / 2) * (H / 2);
+    assert_eq!(REF.len(), i420_len * N_FRAMES, "reference size");
+    for (i, frame) in frames.iter().enumerate() {
+        let c = &frame.content;
+        assert_eq!(c.width, W as u32, "frame {i} width");
+        assert_eq!(c.height, H as u32, "frame {i} height");
+        assert!(
+            matches!(c.format, PixelFormat::Yuv { layout: YuvPixelLayout::Y_U_V420, .. }),
+            "frame {i} must be I420, got {:?}",
+            c.format
+        );
+        // Bit-exact vs the software ffmpeg yuv420p reference: the remuxed container
+        // decodes identically to the raw elementary stream, through the real demuxer.
+        let r = &REF[i * i420_len..(i + 1) * i420_len];
+        assert_eq!(c.data.as_slice(), r, "frame {i} must be bit-exact I420 vs ffmpeg");
+    }
+
+    eprintln!(
+        "mp4_decode: all {N_FRAMES} H.264 frames from a real .mp4 (avcC + AVCC \
+         samples) via re_video::load_mp4 + new_decoder, bit-exact I420 vs ffmpeg"
+    );
+}
diff --git a/crates/utils/re_video_g2g/tests/vulkan_decode.rs b/crates/utils/re_video_g2g/tests/vulkan_decode.rs
new file mode 100644
index 000000000..6673fdbfc
--- /dev/null
+++ b/crates/utils/re_video_g2g/tests/vulkan_decode.rs
@@ -0,0 +1,173 @@
+//! End-to-end proof: an H.264 elementary stream decoded through re_video's own
+//! public decode API (`re_video::new_decoder` -> `AsyncDecoder::submit_chunk` ->
+//! frames on the output channel), with glass2glass' hardware Vulkan Video decoder
+//! as the backend, registered via `re_video_g2g::register()`.
+//!
+//! This is the "demonstrated in Rerun" step of the wgpu-texture wedge: g2g decodes
+//! on the GPU (vendor-neutral Vulkan Video), reads the frame back as I420, and hands
+//! it to re_video, which uploads it and does YUV->RGB on the GPU.
+//!
+//! The g2g backend runs on its own thread and JOINS it on drop, so this exercises
+//! the threaded (non-blocking `submit_chunk`) integration with clean teardown -- the
+//! fix for the double-free the earlier AV1 PoC hit through re_video's detached
+//! `SyncDecoderWrapper`. H.264 (and H.265) decode is bit-identical on any thread;
+//! AV1 has a driver-level off-main-thread residual, so this bit-exact test uses
+//! H.264 (also the most common codec in Rerun-logged video).
+//!
+//! Runs on the RTX 3060; skips gracefully with no Vulkan H.264 decode adapter.
+//! Every frame is checked bit-exact against a software ffmpeg `yuv420p` reference.
+#![cfg(not(target_arch = "wasm32"))]
+
+use std::collections::BTreeMap;
+use std::time::Duration;
+
+use re_video::{
+    Chunk, DecodeError, DecodeSettings, PixelFormat, SamplesStatistics, StableIndexDeque, Time,
+    VideoCodec, VideoDataDescription, VideoDeliveryMethod, YuvPixelLayout, new_decoder,
+};
+
+const CLIP: &[u8] = include_bytes!("../../re_video/tests/fixtures/h264_640x480.h264");
+const REF: &[u8] = include_bytes!("../../re_video/tests/fixtures/h264_640x480_ref.yuv");
+const W: usize = 640;
+const H: usize = 480;
+const N_FRAMES: usize = 10;
+
+/// Split an Annex-B H.264 stream into one slice per access unit (start codes
+/// preserved), the per-sample chunking a demuxer feeds an `AsyncDecoder`. An AU
+/// boundary opens at the first VCL NAL (type 1/5) after a previous VCL NAL, so a
+/// leading SPS/PPS/SEI attaches to the following coded picture.
+fn split_access_units(stream: &[u8]) -> Vec<&[u8]> {
+    // Offsets of every `00 00 01` start code.
+    let mut nal_starts = Vec::new();
+    let mut i = 0;
+    while i + 3 <= stream.len() {
+        if stream[i] == 0 && stream[i + 1] == 0 && stream[i + 2] == 1 {
+            nal_starts.push(i);
+            i += 3;
+        } else {
+            i += 1;
+        }
+    }
+    let mut aus = Vec::new();
+    let mut au_start = 0;
+    let mut seen_vcl = false;
+    for &ns in &nal_starts {
+        // NAL header byte follows the 3-byte start code (a 4-byte start code has a
+        // leading 0 that belongs to this NAL's start; header is still at ns+3).
+        let Some(&hdr) = stream.get(ns + 3) else { continue };
+        let nal_type = hdr & 0x1f;
+        let is_vcl = nal_type == 1 || nal_type == 5;
+        if is_vcl {
+            if seen_vcl {
+                // Close the current AU just before this start code (include a
+                // preceding 4-byte start code's leading zero if present).
+                let cut = if ns > 0 && stream[ns - 1] == 0 { ns - 1 } else { ns };
+                aus.push(&stream[au_start..cut]);
+                au_start = cut;
+            }
+            seen_vcl = true;
+        }
+    }
+    aus.push(&stream[au_start..]);
+    aus
+}
+
+/// A minimal `VideoDataDescription` for a raw H.264 Annex-B elementary stream.
+/// `new_decoder` reads `codec` (and, for mp4, `encoding_details`) to pick a backend;
+/// the g2g Vulkan backend takes its SPS/PPS in-band from the first AU.
+fn h264_description() -> VideoDataDescription {
+    VideoDataDescription {
+        codec: VideoCodec::H264,
+        encoding_details: None,
+        timescale: None,
+        delivery_method: VideoDeliveryMethod::Static { duration: Time(N_FRAMES as i64) },
+        keyframe_indices: vec![0],
+        samples: StableIndexDeque::new(),
+        samples_statistics: SamplesStatistics::NO_BFRAMES,
+        mp4_tracks: BTreeMap::new(),
+    }
+}
+
+#[test]
+fn h264_decodes_through_re_video_with_g2g_backend() {
+    re_video_g2g::register();
+
+    let video = h264_description();
+    let (sender, receiver) = re_video::channel("g2g-h264-poc");
+
+    let mut decoder = match new_decoder("g2g-h264-poc", &video, &DecodeSettings::default(), sender) {
+        Ok(d) => d,
+        // No usable Vulkan H.264 decode adapter and no software fallback compiled in.
+        Err(err) => {
+            eprintln!("skip vulkan_decode: new_decoder unavailable: {err}");
+            return;
+        }
+    };
+
+    let chunks = split_access_units(CLIP);
+    assert_eq!(chunks.len(), N_FRAMES, "fixture is 1 IDR + 9 inter frames");
+
+    // Feed one coded sample per chunk. The g2g backend runs on its own thread;
+    // submit_chunk is non-blocking, so any decode/open error surfaces on the output
+    // channel, not here.
+    for (sample_idx, data) in chunks.iter().enumerate() {
+        decoder
+            .submit_chunk(Chunk {
+                is_sync: sample_idx == 0,
+                data: data.to_vec(),
+                sample_idx,
+                frame_nr: sample_idx as u32,
+                decode_timestamp: Time(sample_idx as i64),
+                presentation_timestamp: Time(sample_idx as i64),
+                duration: Some(Time(1)),
+            })
+            .expect("submit chunk");
+    }
+    decoder.end_of_video().expect("end of video");
+
+    // Drain the frames the decoder pushed onto re_video's output channel.
+    let mut frames = Vec::new();
+    while frames.len() < N_FRAMES {
+        match receiver.recv_timeout(Duration::from_secs(20)) {
+            Ok(Ok(frame)) => frames.push(frame),
+            Ok(Err(DecodeError::HwDecoder(msg)))
+                if frames.is_empty() && msg.contains("open decode device") =>
+            {
+                // No usable Vulkan H.264 decode adapter (e.g. CI). Treat as a skip.
+                eprintln!("skip vulkan_decode: {msg}");
+                return;
+            }
+            Ok(Err(err)) => panic!("decode error after {} frames: {err}", frames.len()),
+            Err(_) => panic!("only got {} of {N_FRAMES} frames", frames.len()),
+        }
+    }
+
+    // The frames flowed through re_video's real decode pipeline. Now verify them.
+    let i420_len = W * H + 2 * (W / 2) * (H / 2);
+    assert_eq!(REF.len(), i420_len * N_FRAMES, "reference size");
+
+    for (i, frame) in frames.iter().enumerate() {
+        let c = &frame.content;
+        assert_eq!(c.width, W as u32, "frame {i} width");
+        assert_eq!(c.height, H as u32, "frame {i} height");
+        assert!(
+            matches!(c.format, PixelFormat::Yuv { layout: YuvPixelLayout::Y_U_V420, .. }),
+            "frame {i} must be I420, got {:?}",
+            c.format
+        );
+        assert_eq!(c.data.len(), i420_len, "frame {i} packed I420 size");
+        // Metadata carried from the chunk through the adapter into re_video.
+        assert_eq!(frame.info.sample_idx, Some(i), "frame {i} sample_idx");
+        assert_eq!(frame.info.presentation_timestamp, Time(i as i64), "frame {i} pts");
+
+        // Bit-exact against the software ffmpeg yuv420p (== I420) reference, full
+        // Y+U+V, so this also validates the NV12 -> I420 chroma deinterleave.
+        let r = &REF[i * i420_len..(i + 1) * i420_len];
+        assert_eq!(c.data.as_slice(), r, "frame {i} must be bit-exact I420 vs ffmpeg");
+    }
+
+    eprintln!(
+        "vulkan_decode: all {N_FRAMES} H.264 frames decoded through \
+         re_video::new_decoder (threaded g2g backend), bit-exact I420 vs ffmpeg"
+    );
+}

+    /// Register an externally-created resource, returning a real handle to it.
+    ///
+    /// Unlike [`Self::alloc`], this pool did not create the resource and does not
+    /// reuse it: the caller owns the underlying GPU object's lifetime (see
+    /// [`super::GpuTexturePool::adopt_external_texture`], which opts the resource out
+    /// of the pool's destroy hook). The handle is a genuine slot so the resource
+    /// resolves through [`Self::get_from_handle`], which bind-group creation needs.
+    /// Keep the returned handle alive while the resource is in use.
+    pub fn alloc_external(
+        &self,
+        desc: &Desc,
+        resource: Res,
+    ) -> Arc<DynamicResource<Handle, Desc, Res>> {
+        let mut state = self.state.write();
+        // Account for the size symmetrically with `begin_frame`'s reclaim, so the
+        // running total stays balanced if the resource is ever dropped + drained.
+        self.total_resource_size_in_bytes.fetch_add(
+            desc.resource_size_in_bytes(),
+            std::sync::atomic::Ordering::Relaxed,
+        );
+        let handle = state.all_resources.insert_with_key(|handle| {
+            Arc::new(DynamicResource {
+                inner: resource,
+                creation_desc: desc.clone(),
+                handle,
+            })
+        });
+        state.all_resources[handle].clone()
+    }

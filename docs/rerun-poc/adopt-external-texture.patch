+    /// Adopt an externally-created [`wgpu::Texture`] (e.g. a hardware-decoded video
+    /// frame, created on the SAME wgpu device) as a [`GpuTexture`] this pool can hand
+    /// to renderers, WITHOUT taking ownership of its GPU memory. The pool never calls
+    /// `destroy()` on it (doing so would double-free a texture `re_renderer` does not
+    /// own); the underlying image is released only when the source and this handle
+    /// both drop, via wgpu's own reference counting. The texture must already carry
+    /// `TEXTURE_BINDING` usage. Keep the returned handle alive for as long as it is
+    /// referenced in a draw.
+    pub fn adopt_external_texture(&self, texture: wgpu::Texture, label: Label) -> GpuTexture {
+        let default_view = texture.create_view(&wgpu::TextureViewDescriptor::default());
+        let creation_desc = TextureDesc {
+            label,
+            size: wgpu::Extent3d {
+                width: texture.width(),
+                height: texture.height(),
+                depth_or_array_layers: texture.depth_or_array_layers(),
+            },
+            mip_level_count: texture.mip_level_count(),
+            sample_count: texture.sample_count(),
+            dimension: texture.dimension(),
+            format: texture.format(),
+            usage: texture.usage(),
+        };
+        self.pool.alloc_external(
+            &creation_desc,
+            GpuTextureInternal {
+                texture,
+                default_view,
+                external: true,
+            },
+        )
+    }
+

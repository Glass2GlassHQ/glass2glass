+    // `alloc_external` registers a caller-owned resource as a real, resolvable slot
+    // (bind-group creation resolves via `get_from_handle`) and accounts its size,
+    // while still surfacing it to the reclaim hook once the handle drops. Whether to
+    // actually free the underlying GPU object is the caller's decision (see
+    // `GpuTexturePool::adopt_external_texture`, which skips `destroy()` for adopted
+    // textures).
+    #[test]
+    fn alloc_external_registers_resolvable_handle() {
+        let mut pool = Pool::default();
+        let size_before = pool.total_resource_size_in_bytes();
+
+        let external = pool.alloc_external(&ConcreteResourceDesc(7), ConcreteResource);
+        let handle = external.handle;
+
+        // A genuine slot: resolves by handle, holds the alloc invariant, counts size.
+        assert!(pool.get_from_handle(handle).is_ok());
+        assert_eq!(Arc::strong_count(&external), 2);
+        assert_eq!(
+            pool.total_resource_size_in_bytes(),
+            size_before + ConcreteResourceDesc(7).resource_size_in_bytes()
+        );
+
+        // Dropping the handle and running maintenance reclaims the slot and reaches the
+        // destroy hook (reuse-eligible: deferred one frame, then drained).
+        drop(external);
+        let mut called_destroy = false;
+        pool.begin_frame(1, |_| called_destroy = true);
+        assert!(!called_destroy);
+        pool.begin_frame(2, |_| called_destroy = true);
+        assert!(called_destroy);
+        assert!(pool.get_from_handle(handle).is_err());
+        assert_eq!(pool.total_resource_size_in_bytes(), size_before);
+    }

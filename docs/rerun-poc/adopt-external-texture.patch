+#[cfg(test)]
+mod tests {
+    use crate::RenderContext;
+
+    /// Adopting an external texture must (a) flag it `external`, (b) resolve through
+    /// the pool by its handle (bind-group creation relies on this), and (c) leave the
+    /// underlying GPU texture intact when the pool reclaims the handle: the external
+    /// owner frees it, not the pool. If `begin_frame` wrongly called `destroy()` on
+    /// it, the GPU write on the retained owner clone below would raise a wgpu
+    /// validation error.
+    #[test]
+    fn adopt_external_texture_resolves_and_survives_reclaim() {
+        re_log::setup_logging();
+        let mut ctx = RenderContext::new_test();
+
+        let external = ctx.device.create_texture(&wgpu::TextureDescriptor {
+            label: Some("external_source"),
+            size: wgpu::Extent3d {
+                width: 16,
+                height: 16,
+                depth_or_array_layers: 1,
+            },
+            mip_level_count: 1,
+            sample_count: 1,
+            dimension: wgpu::TextureDimension::D2,
+            format: wgpu::TextureFormat::Rgba8Unorm,
+            usage: wgpu::TextureUsages::TEXTURE_BINDING | wgpu::TextureUsages::COPY_DST,
+            view_formats: &[],
+        });
+        // Stand in for the external owner (e.g. a hardware video decoder) that keeps
+        // the texture alive independently of the pool.
+        let owner_clone = external.clone();
+
+        let adopted = ctx
+            .gpu_resources
+            .textures
+            .adopt_external_texture(external, "adopted".into());
+        let handle = adopted.handle;
+
+        assert!(adopted.external, "adopted texture must be flagged external");
+        assert!(
+            ctx.gpu_resources.textures.get_from_handle(handle).is_ok(),
+            "adopted texture must resolve through the pool"
+        );
+
+        // Drop our handle and run the pool's frame maintenance until it reclaims the
+        // slot (reuse-eligible resources take two frames: deferred one frame, then
+        // drained). This drives the pool's own destroy hook, the external-skip path
+        // under test.
+        drop(adopted);
+        for frame_index in 1..=3 {
+            ctx.gpu_resources.textures.begin_frame(frame_index);
+        }
+        assert!(
+            ctx.gpu_resources.textures.get_from_handle(handle).is_err(),
+            "reclaimed handle should no longer resolve"
+        );
+
+        // The pool must NOT have destroyed the external texture: a GPU write on the
+        // owner's retained clone still succeeds. A destroyed texture would trip the
+        // validation error scope.
+        let error_scope = ctx.device.push_error_scope(wgpu::ErrorFilter::Validation);
+        ctx.queue.write_texture(
+            wgpu::TexelCopyTextureInfo {
+                texture: &owner_clone,
+                mip_level: 0,
+                origin: wgpu::Origin3d::ZERO,
+                aspect: wgpu::TextureAspect::All,
+            },
+            &[0u8; 16 * 16 * 4],
+            wgpu::TexelCopyBufferLayout {
+                offset: 0,
+                bytes_per_row: Some(16 * 4),
+                rows_per_image: Some(16),
+            },
+            wgpu::Extent3d {
+                width: 16,
+                height: 16,
+                depth_or_array_layers: 1,
+            },
+        );
+        ctx.queue.submit(std::iter::empty::<wgpu::CommandBuffer>());
+        ctx.device
+            .poll(wgpu::PollType::Wait {
+                submission_index: None,
+                timeout: Some(std::time::Duration::from_secs(10)),
+            })
+            .expect("Failed to wait for GPU work to finish");
+        let err = pollster::block_on(error_scope.pop());
+        assert!(
+            err.is_none(),
+            "pool destroyed the adopted external texture: {err:?}"
+        );
+    }
+}
